# Fix 6 Calibration Template
# Copy this to .env or load with 'export $(cat .env.fix6 | xargs)'

# Market Scope
FIX6_SYMBOL=BTCUSDT
FIX6_INTERVAL=5m
FIX6_DAYS=60

# Network Resilience
FIX6_REQUEST_TIMEOUT=30
FIX6_MAX_RETRIES=3
FIX6_RETRY_DELAY=5
FIX6_MIN_SUCCESS_DAYS=30

# Validation Guard
FIX6_EXPECTED_THRESHOLD=0.0025
FIX6_EXPECTED_THRESHOLD_LABEL=0.25%
